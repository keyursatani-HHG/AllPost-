# ------------------------------------------------------------------
# Postly backend — environment configuration
# Copy to `.env` and adjust for your environment.
# ------------------------------------------------------------------

# App
PROJECT_NAME=Postly API
ENVIRONMENT=development            # development | staging | production
DEBUG=true
API_V1_STR=/api/v1

# Security — GENERATE A STRONG SECRET: `openssl rand -hex 32`
SECRET_KEY=change-me-to-a-long-random-secret-string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_EXPIRE_MINUTES=30

# Database (async driver)
DATABASE_URL=postgresql+asyncpg://postly:postly@localhost:5432/postly

# Redis (rate limiting, token deny-list)
REDIS_URL=redis://localhost:6379/0

# CORS — comma-separated list of allowed browser origins
BACKEND_CORS_ORIGINS=http://localhost:3000

# Frontend URL (used to build password-reset links)
FRONTEND_URL=http://localhost:3000

# Refresh-token cookie
REFRESH_COOKIE_NAME=postly_refresh
COOKIE_SECURE=false                # true in production (HTTPS)
COOKIE_SAMESITE=lax                # lax | strict | none
COOKIE_DOMAIN=

# Rate limiting (requests per window, per client)
RATE_LIMIT_PER_MINUTE=120
AUTH_RATE_LIMIT_PER_MINUTE=20

# Google OAuth ("Continue with Google") — leave blank to disable.
# Create an OAuth 2.0 Client ID (type: Web application) at
# https://console.cloud.google.com/apis/credentials and add this exact
# Authorized redirect URI: http://localhost:8000/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# LinkedIn OAuth (to connect a LinkedIn account for posting) — leave blank to disable.
# Create an app at https://www.linkedin.com/developers/apps, request the
# "Sign In with LinkedIn using OpenID Connect" + "Share on LinkedIn" products,
# and add this exact Authorized redirect URL on the app's Auth tab:
#   http://localhost:8000/api/v1/schedule/accounts/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/v1/schedule/accounts/linkedin/callback

# AWS S3 (media storage) — optional in dev
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=postly-media
